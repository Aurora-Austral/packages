module body secret is
    record SecretHandle : Linear is
        val: Nat64;
    end;

    function AccessSecret(id: Nat64): SecretHandle is
        return SecretHandle(val => id);
    end;

    generic [R: Region]
    function RevealSecret(handle: &[SecretHandle, R]): Nat64 is
        return handle->val;
    end;

    function WipeSecret(handle: SecretHandle): Unit is
        let { val as v: Nat64 } := handle;
        return nil;
    end;
end module body.
