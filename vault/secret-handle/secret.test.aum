import secret (
    SecretHandle,
    AccessSecret,
    RevealSecret,
    WipeSecret
);

module body secret_test is
    function TestSecretHandle(): Unit is
        let handle: SecretHandle := AccessSecret(777);
        printLn("Secret accessed.");
        
        let val: Nat64 := RevealSecret(&handle);
        printLn("Secret revealed:");
        printLn(val);
        
        WipeSecret(handle);
        printLn("Secret wiped.");
        return nil;
    end;

    generic function main(root: RootCapability): ExitCode is
        TestSecretHandle();
        surrenderRoot(root);
        return ExitSuccess();
    end;
end module body.
